# ── AI Provider ──────────────────────────────────────────────────────────────
# Supported values: openai | custom | anthropic | watsonx
AI_PROVIDER=openai

# API key for the selected AI provider
AI_API_KEY=your-api-key-here

# ── OpenAI-specific (AI_PROVIDER=openai) ─────────────────────────────────────
# Model to use (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# ── Custom / self-hosted OpenAI-compatible endpoint (AI_PROVIDER=custom) ──────
# Base URL of the API, e.g. https://my-llm-server:8080/api/v1
# AI_BASE_URL=https://your-server:port/api/v1
#
# Model name the server expects, e.g. llama3, mistral, granite-13b-chat
# AI_MODEL=your-model-name
#
# Max tokens the model should generate per response (default: 4096)
# Increase if you see truncated JSON errors in the pipeline log
# AI_MAX_TOKENS=4096
#
# Batch size for graph re-scoring (relationships per AI call, default: 25)
# Lower if re-score calls are still hitting token limits
# AI_RESCORE_BATCH_SIZE=25

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection URL.
# Local dev (no Docker): point to your local Postgres instance.
# Docker: DATABASE_URL is automatically set by docker-compose.yml — no change needed here.
DATABASE_URL=postgresql://kg_user:kg_password@localhost:5432/knowledge_graph

# Password for the PostgreSQL user (used by docker-compose.yml to create the DB container).
# Override in your .env file to a strong random value before deploying.
POSTGRES_PASSWORD=kg_password

# ── Security ─────────────────────────────────────────────────────────────────
# Random secret used to sign JWTs — generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret
