# ── AI Provider ──────────────────────────────────────────────────────────────
# Supported values: openai | custom | anthropic | watsonx
AI_PROVIDER=custom

# API key for the selected AI provider
AI_API_KEY=sk-lm-HgAaNlvj:29NChprk1X5Szz3mwMfn

# ── OpenAI-specific (AI_PROVIDER=openai) ─────────────────────────────────────
# Model to use (default: gpt-4o)
OPENAI_MODEL=google/gemma-4-12b-qat

# ── Custom / self-hosted OpenAI-compatible endpoint (AI_PROVIDER=custom) ──────
# Base URL of the API, e.g. https://my-llm-server:8080/api/v1
 AI_BASE_URL=http://192.168.1.77:1234/api/v1
#
# Model name the server expects, e.g. llama3, mistral, granite-13b-chat
 AI_MODEL=google/gemma-4-12b-qat

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (local dev default). Replace with a postgresql:// URL for production.
# When running via Docker this is automatically overridden to use a named volume.
DATABASE_URL=sqlite:///./knowledge_graph.db

# ── Security ─────────────────────────────────────────────────────────────────
# Random secret used to sign JWTs — generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret
