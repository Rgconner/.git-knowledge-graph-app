# ── AI Provider ────────────────────────────────────────────────────────────────
# Set AI_PROVIDER to one of: openai | custom
# Use "custom" for any self-hosted OpenAI-compatible endpoint (Ollama, vLLM, etc.)
AI_PROVIDER=custom

# Required for both providers
AI_API_KEY=your-api-key-here

# Required for "custom" provider — base URL of your OpenAI-compatible API
AI_BASE_URL=http://your-server:port/api/v1

# Required for "custom" provider — model name your server recognises
AI_MODEL=granite-13b-chat

# Optional for "openai" provider — defaults to gpt-4o
# OPENAI_MODEL=gpt-4o

# ── Token limits ───────────────────────────────────────────────────────────────
# Maximum tokens the model may generate in a single response.
# Applies to ALL calls: entity extraction, relationship inference, sentiment
# scoring, document categorisation, graph re-scoring, and chat.
# 8192 is a safe default for most 13B–70B self-hosted models.
# Increase to 16384 or higher if your model supports it and responses are being
# cut off (watch for finish_reason=length warnings in the backend logs).
AI_MAX_TOKENS=8192

# ── Graph re-scoring ───────────────────────────────────────────────────────────
# Number of relationships sent to the LLM in a single re-scoring batch.
# Smaller batches = more API calls but less risk of hitting context limits.
AI_RESCORE_BATCH_SIZE=25

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection URL. Overridden automatically when running via Docker Compose.
DATABASE_URL=postgresql://kg_user:kg_password@localhost:5432/knowledge_graph

# ── Auth ───────────────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens. Change this to a long random string
# in production. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
# Token expiry in minutes (default: 480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480
